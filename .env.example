# ─────────────────────────────────────────────────────────────
# PCM Texas Action Tracker — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to source control.
# ─────────────────────────────────────────────────────────────

# ── Database (PostgreSQL — Supabase or Railway) ───────────────
DATABASE_URL=jdbc:postgresql://localhost:5432/actiontracker
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=yourpassword

# ── Google OAuth 2.0 ─────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:8080/login/oauth2/code/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Domain restriction ────────────────────────────────────────
# Only @ALLOWED_DOMAIN users can log in
ALLOWED_DOMAIN=digitalchalk.com

# ── Owner account ─────────────────────────────────────────────
# This email gets the OWNER role (sees all tasks)
OWNER_EMAIL=owner@digitalchalk.com

# ── Anthropic Claude API ──────────────────────────────────────
# Get your key at https://console.anthropic.com
CLAUDE_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ── Gmail Notifications ───────────────────────────────────────
# Service account JSON key path OR OAuth credentials for Gmail API
GMAIL_FROM_ADDRESS=notifications@digitalchalk.com
# Path to Google service account JSON key file (for Gmail API)
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=/secrets/google-service-account.json

# ── Application URLs ──────────────────────────────────────────
FRONTEND_URL=http://localhost:4200
# Production: FRONTEND_URL=https://your-app.vercel.app

# ── Spring Boot ───────────────────────────────────────────────
# Set to 'prod' in production
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# ── AWS Configuration ─────────────────────────────────────────────────────────
# Required for production deployment on AWS App Runner

# AWS region where all resources are deployed
AWS_REGION=us-east-1

# AWS credentials (use IAM role in production App Runner — these are for local dev only)
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# AWS Secrets Manager — ARN of the secret containing all app secrets
# The secret must be a JSON object with these keys:
#   DATABASE_URL, DATABASE_USERNAME, DATABASE_PASSWORD,
#   GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET,
#   CLAUDE_API_KEY, GMAIL_FROM_ADDRESS, OWNER_EMAIL, FRONTEND_URL
AWS_SECRETS_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:actiontracker/prod-AbCdEf

# ── Amazon RDS (PostgreSQL 15) ────────────────────────────────────────────────
# Used directly in local dev; in production these come from AWS Secrets Manager
DATABASE_URL=jdbc:postgresql://your-rds-endpoint.us-east-1.rds.amazonaws.com:5432/actiontracker
DATABASE_USERNAME=actiontracker
DATABASE_PASSWORD=yourSecurePassword

# ── Amazon ECR ────────────────────────────────────────────────────────────────
# Your AWS account ID (used to build ECR image URLs)
AWS_ACCOUNT_ID=123456789012
ECR_REPOSITORY=actiontracker-backend

# ── AWS App Runner ────────────────────────────────────────────────────────────
# The ARN of the App Runner service (set after creating the service)
# Used by GitHub Actions to trigger deployments
APPRUNNER_SERVICE_ARN=arn:aws:apprunner:us-east-1:123456789012:service/actiontracker-backend/abc123

# ── Spring Profile ────────────────────────────────────────────────────────────
# Set to 'prod' in App Runner environment variables to activate AWS Secrets Manager
SPRING_PROFILES_ACTIVE=prod
